{
  "installCommand": "cd web_demo && npm ci",
  "buildCommand": "cd web_demo && npm run build",
  "outputDirectory": "web_demo/dist",
  "routes": [
    {
      "src": "/health",
      "dest": "/api/index.py"
    },
    {
      "src": "/render",
      "dest": "/api/index.py"
    },
    {
      "src": "/preview.png",
      "dest": "/api/index.py"
    },
    {
      "src": "/font-health",
      "dest": "/api/index.py"
    },
    {
      "src": "/parse-rbxm",
      "dest": "/api/parse_rbxm.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
